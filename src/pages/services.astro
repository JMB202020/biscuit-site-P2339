---
import '../styles/site.css';
const nav = [
  { label: 'Home',     href: '/P2339' },
  { label: 'Services', href: '/P2339/services' },
  { label: 'Gallery',  href: '/P2339/gallery' },
  { label: 'Contact',  href: '/P2339/contact' },
];
const phone = '01643 707182';
const phoneHref = 'tel:+441643707182';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Services &amp; Prices | The Iggy Haven, Minehead</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/P2339/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/P2339/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>The Iggy Haven</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=P2339&name=The%20Iggy%20Haven" class="inline-flex items-center px-4 py-1 bg-white text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-white-warm border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/P2339" class="font-display font-extrabold text-xl text-ink">The Iggy Haven</a>
        <button class="md:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav-svc').classList.toggle('hidden')" aria-label="Open menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-6">
          {nav.map(n => (
            <a href={n.href} class={`text-sm font-semibold transition-colors ${n.href === '/P2339/services' ? 'text-brand-accent' : 'text-ink-soft hover:text-brand-accent'}`}>{n.label}</a>
          ))}
          <a href={phoneHref} class="inline-flex items-center px-5 py-2 bg-brand-accent text-white font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">{phone}</a>
        </nav>
      </div>
      <nav id="mobile-nav-svc" class="hidden md:hidden px-6 pb-4 space-y-3 border-t border-border pt-4">
        {nav.map(n => (
          <a href={n.href} class="text-ink-soft block text-sm font-semibold hover:text-brand-accent">{n.label}</a>
        ))}
        <a href={phoneHref} class="block px-5 py-2.5 bg-brand-accent text-white font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">{phone}</a>
      </nav>
    </header>

    <!-- Page header -->
    <section class="py-14 sm:py-20 bg-brand-hero">
      <div class="mx-auto max-w-7xl px-6">
        <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-5 bg-white/15 text-white border border-white/20">📍 Minehead</p>
        <h1 class="font-display font-extrabold text-3xl sm:text-5xl lg:text-6xl text-white leading-tight max-w-2xl">Services &amp; pricing</h1>
        <p class="mt-4 text-white/85 text-lg max-w-xl">Everything The Iggy Haven offers, with clear, honest pricing.</p>
      </div>
    </section>

    <!-- About Us section -->
    <section class="bg-white py-16 sm:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="flex flex-col sm:flex-row gap-8 items-start sm:items-center mb-10">
          <div class="w-20 h-20 rounded-full bg-brand-accent flex items-center justify-center text-white font-display font-extrabold text-3xl shrink-0">I</div>
          <div>
            <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-ink">About us</h2>
            <p class="text-ink-soft mt-1">The Iggy Haven, 13 Regents Way, Minehead</p>
          </div>
        </div>
        <div class="border-2 border-dashed border-border rounded-2xl p-8">
          <p class="text-ink-soft italic text-lg">Tell your customers about The Iggy Haven here. Your background, your experience, what you love about caring for pets, and what makes your boarding different from others in the area.</p>
          <p class="text-ink-whisper text-sm mt-4">We will add your story here when you get in touch.</p>
        </div>
      </div>
    </section>

    <!-- What we offer -->
    <section class="bg-cream py-16 sm:py-24">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-ink mb-10">What we offer</h2>
        <div class="space-y-5">
          {[
            { icon: '🏠', label: 'Overnight boarding' },
            { icon: '☀️', label: 'Day care' },
            { icon: '🌴', label: 'Holiday boarding' },
            { icon: '🐾', label: 'Other services' },
          ].map(s => (
            <div class="bg-white rounded-2xl border border-border p-7 shadow-sm">
              <div class="flex items-center gap-4 mb-4">
                <span class="text-2xl" aria-hidden="true">{s.icon}</span>
                <h3 class="font-display font-bold text-xl text-ink">{s.label}</h3>
              </div>
              <div class="border-2 border-dashed border-border rounded-xl p-5">
                <p class="text-ink-soft italic text-sm">Describe this service in 2 to 3 sentences. Include what is included, what to expect, and any specific requirements.</p>
                <p class="text-ink-whisper text-xs mt-2">We will add your service details here when you get in touch.</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="bg-cream-dark py-16 sm:py-24">
      <div class="mx-auto max-w-4xl px-6">
        <div class="text-center mb-12">
          <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-ink">Pricing</h2>
          <p class="mt-3 text-ink-soft text-lg">Clear, upfront pricing with no hidden costs.</p>
        </div>
        <div class="border-2 border-dashed border-border rounded-2xl p-10 bg-white text-center">
          <p class="text-ink-soft italic text-lg">Add your pricing here. For example: overnight rate per pet, weekly rate, day care rate, any additional charges for bank holidays or extra pets.</p>
          <p class="text-ink-whisper text-sm mt-4">We will add your pricing when you get in touch.</p>
        </div>

        <div class="mt-10 bg-accent-light rounded-2xl p-8 border border-border">
          <h3 class="font-display font-bold text-xl text-ink mb-3">Not sure what you need?</h3>
          <p class="text-ink-soft text-sm mb-5">Give us a ring and we can talk through the right option for your pet. No pressure, no fuss.</p>
          <a href={phoneHref} class="inline-flex items-center px-6 py-3 bg-brand-accent text-white font-display font-bold text-sm rounded-xl hover:bg-brand-accent-deep transition-all">
            Call us: {phone}
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 sm:py-20 bg-brand-hero">
      <div class="mx-auto max-w-2xl px-6 text-center">
        <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-white mb-4">Ready to make a booking?</h2>
        <p class="text-white/85 text-lg mb-8">Call us to check availability or pop us a message via our contact page.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={phoneHref} class="inline-flex items-center px-8 py-4 bg-brand-accent text-white font-display font-bold text-lg rounded-xl hover:bg-brand-accent-deep transition-all shadow-md">
            📞 {phone}
          </a>
          <a href="/P2339/contact" class="inline-flex items-center px-8 py-4 border-2 border-white text-white font-display font-bold text-base rounded-xl hover:bg-white/10 transition-all">
            Contact form
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-cream-dark border-t border-border py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <div>
            <span class="font-display font-extrabold text-xl text-ink">The Iggy Haven</span>
            <p class="text-ink-soft text-sm mt-3">Pet boarding in Minehead, Somerset. A safe, homely stay for your pets.</p>
          </div>
          <div>
            <h4 class="font-display font-bold text-sm text-ink mb-4 uppercase tracking-wider">Pages</h4>
            <ul class="space-y-2">
              {nav.map(n => (
                <li><a href={n.href} class="text-sm text-ink-soft hover:text-brand-accent transition-colors">{n.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="font-display font-bold text-sm text-ink mb-4 uppercase tracking-wider">Contact</h4>
            <p class="text-sm text-ink-soft">
              <a href={phoneHref} class="hover:text-brand-accent transition-colors">{phone}</a>
            </p>
            <p class="text-sm text-ink-soft mt-2">13 Regents Way<br />Minehead<br />Somerset</p>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-border">
          <p class="text-ink-whisper text-xs">&copy; 2026 The Iggy Haven. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
